PORT=5000

# Shared MySQL DB (Member 1 owns schema migrations for the whole project)
DATABASE_URL="mysql://user:password@localhost:3306/transitops"

# JWT (Member 1's auth module issues these; we only verify)
JWT_SECRET=replace_with_shared_team_secret

# Member 2's Vehicle/Driver API base URL - never query their tables directly
VEHICLE_DRIVER_API_BASE_URL=http://localhost:5000/api
